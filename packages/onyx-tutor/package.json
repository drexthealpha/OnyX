{
    "name": "@onyx/tutor",
    "version": "1.0.0",
    "description": "Persistent learner model and TutorBot system for ONYX",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc --emitDeclarationOnly && tsup src/index.ts --format esm",
        "dev": "tsup src/index.ts --watch",
        "test": "vitest run"
    },
    "dependencies": {
        "@onyx/markitdown": "workspace:*",
        "@onyx/mem": "workspace:*",
        "@onyx/semantic": "workspace:*",
        "hono": "^4.12.17"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "@onyx/mem": "workspace:*"
    },
    "publishConfig": {
        "access": "public"
    }
}
