{
    "name":  "@onyx/hermes",
    "version":  "1.0.0",
    "description":  "Self-evolving memory and skill improvement engine for ONYX",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "scripts":  {
                    "build":  "tsc",
                    "dev":  "ts-node src/index.ts",
                    "start":  "node dist/index.js",
                    "test":  "vitest run"
                },
    "dependencies":  {
                         "better-sqlite3":  "^9.4.3",
                         "express":  "^4.18.2",
                         "node-cron":  "^3.0.3",
                         "uuid":  "^9.0.0",
                         "zod":  "^3.22.4"
                     },
    "devDependencies":  {
                            "@types/better-sqlite3":  "^7.6.8",
                            "@types/express":  "^4.17.21",
                            "@types/node":  "^20.11.5",
                            "@types/node-cron":  "^3.0.11",
                            "@types/uuid":  "^9.0.7",
                            "typescript":  "^5.3.3",
                            "vitest":  "latest"
                        },
    "type":  "module",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js"
                          }
                },
    "publishConfig":  {
                          "access":  "public"
                      }
}
