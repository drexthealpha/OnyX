{
  "name": "@onyx/control",
  "version": "0.1.0",
  "description": "Ink TUI for terminal control of ONYX",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "onyx-control": "bin/onyx-control.js" },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ink-testing-library": "^3.0.0"
  },
  "engines": { "node": ">=20.0.0" }
}