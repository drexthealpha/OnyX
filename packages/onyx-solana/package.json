{
    "name": "@onyx/solana",
    "version": "1.0.0",
    "description": "ONYX Solana MCP tools — 31 tools covering wallet, Helius, Jupiter, BirdEye, PumpFun, SPL, NFT, staking, and privacy",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./tools/*": {
            "types": "./dist/tools/*.d.ts",
            "import": "./dist/tools/*.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch",
        "test": "vitest run",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@onyx/bridge": "workspace:*",
        "@solana/kit": "latest",
        "@solana/signers": "latest",
        "axios": "^1.16.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^22.19.17",
        "rimraf": "^5.0.10",
        "typescript": "^5.9.3",
        "vitest": "^1.6.1"
    },
    "engines": {
        "node": ">=20"
    },
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
