{
    "name": "@onyx/swe",
    "version": "1.0.0",
    "description": "Autonomous software engineering agent for ONYX — plans, codes, tests, reviews, and opens PRs from GitHub issues",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "type-check": "tsc --noEmit",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@octokit/rest": "^21.1.1",
        "dockerode": "^4.0.12"
    },
    "devDependencies": {
        "@types/dockerode": "^3.3.47",
        "@types/node": "^22.19.17",
        "typescript": "^5.9.3",
        "vitest": "^3.2.4"
    },
    "peerDependencies": {
        "@onyx/mem": "workspace:*"
    },
    "keywords": [
        "onyx",
        "swe",
        "agent",
        "github",
        "docker",
        "autonomous"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
