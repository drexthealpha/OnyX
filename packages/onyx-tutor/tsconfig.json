{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@onyx/mem": [
        "../onyx-mem/src/index.ts"
      ],
      "@onyx/semantic": [
        "../onyx-semantic/src/index.ts"
      ],
      "@onyx/markitdown": [
        "../onyx-markitdown/src/index.ts"
      ]
    },
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "extends": "../../tsconfig.base.json"
}