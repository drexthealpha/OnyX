{
    "name": "@onyx/bridge",
    "version": "1.0.0",
    "description": "Ika dWallet MPC integration for ONYX keyless signing",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "type": "module",
    "private": true,
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "test": "vitest run",
        "lint": "tsc --noEmit",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@grpc/grpc-js": "1.12.6",
        "@mysten/bcs": "^1.9.2",
        "@onyx/kernel": "workspace:*",
        "@solana-program/system": "^0.12.0",
        "@solana/accounts": "^6.8.0",
        "@solana/addresses": "^6.8.0",
        "@solana/codecs": "^6.8.0",
        "@solana/compat": "^6.8.0",
        "@solana/errors": "^6.8.0",
        "@solana/functional": "^6.8.0",
        "@solana/keys": "^6.8.0",
        "@solana/kit": "^6.8.0",
        "@solana/kit-plugin-rpc": "^0.11.1",
        "@solana/kit-plugin-signer": "^0.10.0",
        "@solana/rpc": "^6.8.0",
        "@solana/rpc-subscriptions": "^6.8.0",
        "@solana/signers": "^6.8.0",
        "@solana/spl-token": "^0.4.14",
        "@solana/sysvars": "^5.5.1",
        "@solana/transaction-messages": "^6.8.0",
        "@solana/transactions": "^6.8.0",
        "@solana/webcrypto-ed25519-polyfill": "^6.8.0",
        "better-sqlite3": "^9.6.0",
        "bs58": "^6.0.0",
        "js-sha3": "^0.9.3",
        "tweetnacl": "^1.0.3"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^20.19.39",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "publishConfig": {
        "access": "public"
    }
}
