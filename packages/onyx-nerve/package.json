{
    "name": "@onyx/nerve",
    "version": "1.0.0",
    "description": "ONYX cockpit backend (Hono) + React 19 dashboard UI",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "pnpm src/index.ts",
        "dev:ui": "vite ui/",
        "build:ui": "vite build ui/",
        "test": "vitest run"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.1",
        "@onyx/agent": "workspace:*",
        "@onyx/intel": "workspace:*",
        "@onyx/mem": "workspace:*",
        "@onyx/multica": "workspace:*",
        "@onyx/research": "workspace:*",
        "@onyx/rl": "workspace:*",
        "@onyx/router": "workspace:*",
        "@onyx/trading": "workspace:*",
        "@onyx/tutor": "workspace:*",
        "@onyx/vault": "workspace:*",
        "hono": "^4.12.17",
        "pino": "^10.3.1",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.4",
        "@types/bun": "latest",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^5.2.0",
        "tailwindcss": "^4.2.4",
        "typescript": "~5.9.3",
        "vite": "^7.3.2",
        "vitest": "latest"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    }
}
