{
    "name":  "@onyx/vault",
    "version":  "1.0.0",
    "description":  "ONYX secure wallet vault — keypair loaded from user-provided path, private key never exposed after init",
    "type":  "module",
    "main":  "dist/index.js",
    "types":  "dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js"
                          }
                },
    "scripts":  {
                    "build":  "tsc",
                    "dev":  "tsc --watch",
                    "test":  "node --test dist/**/*.test.js",
                    "clean":  "rm -rf dist"
                },
    "devDependencies":  {
                            "@types/node":  "^22.0.0",
                            "rimraf":  "^6.1.3",
                            "typescript":  "^5.8.0"
                        },
    "engines":  {
                    "node":  "\u003e=20"
                },
    "license":  "MIT",
    "dependencies":  {
                         "@solana/web3.js":  "^1.98.4",
                         "bs58":  "^6.0.0",
                         "tweetnacl":  "^1.0.3"
                     },
    "publishConfig":  {
                          "access":  "public"
                      }
}
