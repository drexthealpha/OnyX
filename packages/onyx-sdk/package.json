{
    "name": "@onyx/sdk",
    "version": "1.0.0",
    "description": "ONYX — Sovereign AI OS on Solana — public TypeScript SDK",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./react": {
            "import": "./dist/react/OnyxProvider.js",
            "types": "./dist/react/OnyxProvider.d.ts"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "test": "vitest run",
        "lint": "tsc --noEmit",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "dependencies": {
        "@onyx/agent": "workspace:*",
        "@onyx/compute": "workspace:*",
        "@onyx/intel": "workspace:*",
        "@onyx/privacy": "workspace:*",
        "@onyx/research": "workspace:*",
        "@onyx/trading": "workspace:*",
        "@onyx/tutor": "workspace:*",
        "@onyx/vault": "workspace:*"
    },
    "devDependencies": {
        "@testing-library/react": "^14.3.1",
        "@types/node": "^20.19.39",
        "@types/react": "19.2.14",
        "jsdom": "^24.1.3",
        "react": "19.0.0",
        "react-dom": "19.0.0",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "keywords": [
        "onyx",
        "solana",
        "ai",
        "agent",
        "sdk",
        "sovereign"
    ],
    "license": "MIT",
    "type": "module",
    "publishConfig": {
        "access": "public"
    }
}
