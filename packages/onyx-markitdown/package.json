{
    "name":  "@onyx/markitdown",
    "version":  "1.0.0",
    "description":  "Universal document-to-markdown converter for ONYX AI OS",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "scripts":  {
                    "build":  "tsc",
                    "test":  "vitest run",
                    "dev":  "tsc --watch"
                },
    "dependencies":  {
                         "pdf-parse":  "^1.1.1",
                         "mammoth":  "^1.8.0",
                         "xlsx":  "^0.18.5",
                         "turndown":  "^7.2.0",
                         "fluent-ffmpeg":  "^2.1.3",
                         "jszip":  "^3.10.1",
                         "xml2js":  "^0.6.2"
                     },
    "devDependencies":  {
                            "@types/pdf-parse":  "^1.1.4",
                            "@types/turndown":  "^5.0.5",
                            "@types/fluent-ffmpeg":  "^2.1.27",
                            "@types/node":  "^20.0.0",
                            "@types/xml2js":  "^0.4.14",
                            "typescript":  "^5.4.0",
                            "vitest":  "latest"
                        },
    "peerDependencies":  {
                             "@anthropic-ai/sdk":  "^0.39.0"
                         },
    "peerDependenciesMeta":  {
                                 "@anthropic-ai/sdk":  {
                                                           "optional":  true
                                                       }
                             },
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js"
                          }
                },
    "publishConfig":  {
                          "access":  "public"
                      }
}
