{
    "name": "@onyx/privacy",
    "version": "1.0.0",
    "description": "Umbra SDK integration for ONYX financial privacy on Solana",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@solana/kit": "latest",
        "@umbra-privacy/sdk": "2.0.3",
        "@umbra-privacy/web-zk-prover": "latest",
        "comlink": "^4.4.2"
    },
    "devDependencies": {
        "typescript": "^5.9.3",
        "vitest": "^1.6.1"
    },
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    }
}
