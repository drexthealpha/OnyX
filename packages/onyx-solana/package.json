{
    "name":  "@onyx/solana",
    "version":  "1.0.0",
    "description":  "ONYX Solana MCP tools — 31 tools covering wallet, Helius, Jupiter, BirdEye, PumpFun, SPL, NFT, staking, and privacy",
    "type":  "module",
    "main":  "dist/index.js",
    "types":  "dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js"
                          },
                    "./tools/*":  {
                                      "types":  "./dist/tools/*.d.ts",
                                      "import":  "./dist/tools/*.js"
                                  }
                },
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "dev":  "tsc -p tsconfig.json --watch",
                    "test":  "vitest run",
                    "clean":  "rimraf dist"
                },
    "dependencies":  {
                         "@onyx/bridge":  "workspace:*",
                         "@solana/web3.js":  "^1.91.8",
                         "@solana/spl-token":  "^0.4.6",
                         "axios":  "^1.7.2",
                         "zod":  "^3.23.8"
                     },
    "devDependencies":  {
                            "@types/node":  "^22.0.0",
                            "rimraf":  "^5.0.5",
                            "typescript":  "^5.8.0",
                            "vitest":  "^1.6.0"
                        },
    "engines":  {
                    "node":  "\u003e=20"
                },
    "license":  "MIT",
    "publishConfig":  {
                          "access":  "public"
                      }
}
