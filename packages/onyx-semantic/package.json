{
    "name": "@onyx/semantic",
    "version": "1.0.0",
    "description": "Qdrant vector store layer for all ONYX memory — local inference, zero API cost",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@qdrant/js-client-rest": "^1.17.0",
        "@xenova/transformers": "^2.17.2"
    },
    "devDependencies": {
        "@types/node": "^20.19.39",
        "typescript": "^5.9.3",
        "vitest": "^1.6.1"
    },
    "engines": {
        "node": ">=18.17.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
