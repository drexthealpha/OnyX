{
    "name": "@onyx/rl",
    "version": "1.0.0",
    "description": "Reinforcement learning loop for ONYX — wired to every conversation",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "pnpm --watch src/index.ts",
        "start": "node dist/index.js",
        "test": "vitest run"
    },
    "dependencies": {
        "better-sqlite3": "^9.6.0",
        "hono": "^4.12.17"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^20.19.39",
        "typescript": "^5.9.3",
        "vitest": "latest"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    }
}
