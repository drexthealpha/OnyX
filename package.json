{
  "name": "onyx",
  "version": "0.0.1",
  "private": true,
  "description": "Sovereign AI OS on Solana — 37 packages, 9 layers, zero operator cost",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:s34:web-build": "pnpm --filter onyx-web build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter onyx-web dev",
    "dev:mobile": "pnpm --filter onyx-mobile start",
    "dev:desktop": "pnpm --filter onyx-desktop dev",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\"",
    "publish:all": "pnpm publish -r --access public --no-git-checks",
    "docker:build": "docker build -t ghcr.io/drexthealpha/onyx-gateway:latest -f packages/onyx-gateway/Dockerfile .",
    "docker:push": "docker push ghcr.io/drexthealpha/onyx-gateway:latest",
    "deploy:web": "pnpm --filter onyx-web build && vercel --cwd apps/web --prod --yes",
    "demo:fhe": "tsx scripts/demo-fhe-vault.ts",
    "demo:umbra": "tsx scripts/demo-umbra.ts",
    "demo:ika": "tsx scripts/demo-ika.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "turbo": "^1.13.2",
    "typescript": "^5.4.5",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "dependencies": {
    "@umbra-privacy/sdk": "2.0.3",
    "utf-8-validate": "^5.0.2",
    "whatwg-url": "7.1.0",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "zod": "^4.4.3",
      "whatwg-url": "7.1.0",
      "utf-8-validate": "^5.0.2",
      "@umbra-privacy/sdk": "2.0.3",
      "@solana/sysvars": "^5.0",
      "bare-https": "^2.1.3",
      "expo-constants": "~17.0.8"
    },
    "peerDependencyOverrides": {
      "whatwg-url": "7.1.0",
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "expo-constants": "~17.0.8"
    }
  }
}