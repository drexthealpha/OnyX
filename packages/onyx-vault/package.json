{
    "name": "@onyx/vault",
    "version": "1.0.0",
    "description": "ONYX secure wallet vault — keypair loaded from user-provided path, private key never exposed after init",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "node --test dist/**/*.test.js",
        "clean": "rm -rf dist"
    },
    "devDependencies": {
        "@types/node": "^22.19.17",
        "rimraf": "^6.1.3",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=20"
    },
    "license": "MIT",
    "dependencies": {
        "@solana/kit": "latest",
        "bs58": "^6.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
