{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ONYX",
  "version": "0.1.0",
  "identifier": "ai.onyx.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter onyx-web dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ONYX",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}