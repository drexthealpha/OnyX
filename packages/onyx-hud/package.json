{
    "name": "@onyx/hud",
    "version": "1.0.0",
    "description": "Screen-aware AI HUD overlay — transparent Electron window with context metering, tool display, agent tracking, and screen capture injection",
    "main": "./dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "electron dist/index.js",
        "dev": "tsc --watch",
        "test": "vitest run"
    },
    "dependencies": {
        "electron": "^33.4.11",
        "jimp": "^1.6.1",
        "screenshot-desktop": "^1.15.4"
    },
    "devDependencies": {
        "@types/node": "^22.19.17",
        "bun-types": "^1.3.13",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "@onyx/markitdown": "workspace:*",
        "@onyx/multica": "workspace:*",
        "@onyx/rl": "workspace:*"
    },
    "peerDependenciesMeta": {
        "@onyx/markitdown": {
            "optional": true
        },
        "@onyx/multica": {
            "optional": true
        },
        "@onyx/rl": {
            "optional": true
        }
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "types": "./dist/index.d.ts",
    "publishConfig": {
        "access": "public"
    }
}
