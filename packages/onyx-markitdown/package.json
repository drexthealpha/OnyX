{
    "name": "@onyx/markitdown",
    "version": "1.0.0",
    "description": "Universal document-to-markdown converter for ONYX AI OS",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "dev": "tsc --watch"
    },
    "dependencies": {
        "fluent-ffmpeg": "^2.1.3",
        "jszip": "^3.10.1",
        "mammoth": "^1.12.0",
        "pdf-parse": "^1.1.4",
        "turndown": "^7.2.4",
        "xlsx": "^0.18.5",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/node": "^20.19.39",
        "@types/pdf-parse": "^1.1.5",
        "@types/turndown": "^5.0.6",
        "@types/xml2js": "^0.4.14",
        "typescript": "^5.9.3",
        "vitest": "latest"
    },
    "peerDependencies": {
        "@anthropic-ai/sdk": "^0.39.0"
    },
    "peerDependenciesMeta": {
        "@anthropic-ai/sdk": {
            "optional": true
        }
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    }
}
